  "strings": {
    "%@ on %@ is %@ %@ now, averaging %@ %@ across %lld readings (range %@–%@ %@, %@).": {
      "localizations": {
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$@ en %2$@ es %3$@ %4$@ ahora, con un promedio de %5$@ %6$@ en %7$lld lecturas (rango %8$@–%9$@ %10$@, %11$@)."
          }
        }
      }
    },
    "%lld active alerts open on this device.": {
      "localizations": {
        "en": {
          "variations": {
            "plural": {
              "one": {
                "stringUnit": {
                  "state": "translated",
                  "value": "%lld active alert open on this device."
